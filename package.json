{
  "name": "tailwind-canonical",
  "version": "0.1.8",
  "description": "Lint and auto-fix Tailwind CSS arbitrary values that have canonical equivalents",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": {
      "import": "./dist/eslint/plugin.js",
      "types": "./dist/eslint/plugin.d.ts"
    }
  },
  "bin": {
    "tailwind-canonical": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peak-lab/tailwind-canonical.git"
  },
  "bugs": {
    "url": "https://github.com/peak-lab/tailwind-canonical/issues"
  },
  "homepage": "https://github.com/peak-lab/tailwind-canonical#readme",
  "author": "Fahari Hamada Sidi",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import=tsx/esm --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepare": "lefthook install || true",
    "prepublishOnly": "pnpm build",
    "knip": "knip"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "linter",
    "canonical",
    "arbitrary-values",
    "eslint-plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.0.0",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    }
  }
}
